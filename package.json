{
  "name": "icon-style-mvp",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "node --experimental-strip-types apps/server/src/index.ts",
    "dev": "node --experimental-strip-types apps/server/src/index.ts",
